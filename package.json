{
  "name": "@adrianapan/pikit",
  "version": "1.0.2",
  "description": "An opinionated pi.dev configuration. Batteries included — 16 extensions, 4 skills, prompt templates, and the slop theme in one package.",
  "license": "MIT",
  "author": "Adrian Apan",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adrianapan/pikit.git"
  },
  "homepage": "https://github.com/adrianapan/pikit#readme",
  "bugs": {
    "url": "https://github.com/adrianapan/pikit/issues"
  },
  "keywords": [
    "pi",
    "pi-package",
    "pi-coding-agent",
    "pikit"
  ],
  "files": [
    "agent/extensions",
    "agent/themes/slop.json",
    "agent/skills",
    "agent/prompts",
    "README.md",
    "banner.png"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "release": "npm publish --access public"
  },
  "pi": {
    "extensions": [
      "./agent/extensions/*/index.ts"
    ],
    "skills": [
      "./agent/skills"
    ],
    "prompts": [
      "./agent/prompts"
    ],
    "themes": [
      "./agent/themes/slop.json"
    ],
    "image": "https://raw.githubusercontent.com/adrianapan/pikit/main/banner.png"
  },
  "dependencies": {
    "typebox": "^1.1.38",
    "@mozilla/readability": "^0.5.0",
    "linkedom": "^0.16.0",
    "turndown": "^7.2.0",
    "unpdf": "^1.4.0",
    "diff2html": "^3.4.52",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.5"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "@earendil-works/pi-ai": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.80.3",
    "@earendil-works/pi-coding-agent": "^0.80.3",
    "@earendil-works/pi-tui": "^0.80.3",
    "@types/node": "^25.6.2",
    "typescript": "^6.0.3"
  }
}
